# Copy this file to .env.local and fill in your keys.

# OpenAI — used for Whisper speech-to-text transcription.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic — used for Claude summarisation and note generation.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Vercel Blob — enables uploads larger than the ~4.5 MB serverless function
# body limit (files are uploaded straight to Blob storage, then transcribed and
# deleted). On Vercel: create a Blob store and this is injected automatically.
# Locally: run `vercel env pull` or paste the token here.
# Files <= 4 MB still work without this (they upload directly to the API).
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Optional: override the default models.
# OPENAI_TRANSCRIBE_MODEL=whisper-1
# ANTHROPIC_MODEL=claude-sonnet-5
